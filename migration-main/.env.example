# ==============================
# Oracle DB
# ==============================
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_DSN=
ORACLE_CLIENT_LIB_DIR=C:\oracle\instantclient_21_20

# ==============================
# XML Parser
# ==============================
MAPPER_XML_SOURCE_DIR=
XML_PARSER_DATA_DIR=
ACTIVE_SQL_ID_TABLE=
ACTIVE_SQL_ID_COLUMN=SQL_ID
# 주의: ACTIVE_SQL_ID_COLUMN 값은 반드시 "NAMESPACE.SQL_ID" 형식이어야 함
TEST_MAPPING_TABLES=

# ==============================
# LLM
# ==============================
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=

# ==============================
# Feedback RAG / Embedding
# ==============================
# 임베딩 API URL
# - 루트 URL, /v1, /v1/embeddings 모두 입력 가능 (코드에서 자동 보정)
RAG_EMBED_BASE_URL=
# 임베딩 모델명
RAG_EMBED_MODEL=BAAI/bge-m3
# 임베딩 API 키(필요 시)
RAG_EMBED_API_KEY=
# 임베딩 API 타임아웃(초)
RAG_EMBED_TIMEOUT_SEC=30

# 벡터 인덱스 저장 DB 경로
RAG_VECTOR_DB_PATH=migration.db
# 벡터 인덱스 테이블명
RAG_VECTOR_TABLE=feedback_rag_index
# 검색 상위 K
RAG_TOP_K=5
# 코퍼스 최대 로드 건수
RAG_CORPUS_LIMIT=2000
