# Oracle 접속 계정
ORACLE_USER=
# Oracle 접속 비밀번호
ORACLE_PASSWORD=
# Oracle DSN (예: 127.0.0.1:1521/ORCLPDB1)
ORACLE_DSN=
# Oracle Instant Client 설치 경로
ORACLE_CLIENT_LIB_DIR=C:\oracle\instantclient_21_20

# Mapper XML 원본 디렉토리 경로
MAPPER_XML_SOURCE_DIR=
# XML 파싱 결과(JSON) 저장 디렉토리 경로 (비우면 기본 app/services/DATA)
XML_PARSER_DATA_DIR=
# 현재 실제 사용 중인 SQL_ID 목록을 가진 테이블명
ACTIVE_SQL_ID_TABLE=
# ACTIVE_SQL_ID_TABLE에서 SQL_ID가 들어있는 컬럼명 (기본 SQL_ID)
ACTIVE_SQL_ID_COLUMN=SQL_ID
# 테스트 대상 매핑 테이블 목록
# 예: TB_ORDER,TB_ORDER_DTL
# 예: ["TB_ORDER","SCHEMA.TB_ORDER_DTL"]
TEST_MAPPING_TABLES=

# LLM API 키
LLM_API_KEY=
# LLM 모델명
LLM_MODEL=
# LLM Base URL
LLM_BASE_URL=
