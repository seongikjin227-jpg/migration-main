# ==============================
# Oracle DB
# ==============================
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_DSN=
ORACLE_SCHEMA=
ORACLE_CLIENT_LIB_DIR=C:\oracle\instantclient_21_20

# ==============================
# XML Parser
# ==============================
MAPPER_XML_SOURCE_DIR=
XML_PARSER_DATA_DIR=
ACTIVE_SQL_ID_TABLE=
ACTIVE_SQL_ID_COLUMN=SQL_ID
# 주의: ACTIVE_SQL_ID_COLUMN 값은 반드시 "NAMESPACE.SQL_ID" 형식이어야 함
TEST_MAPPING_TABLES=

# ==============================
# LLM
# ==============================
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=

# ==============================
# Shared Embedding / Legacy Feedback RAG
# ==============================
# 아래 임베딩 설정은 legacy feedback RAG와 TOBE RAG가 공통으로 사용함
# 임베딩 API URL
# - 루트 URL, /v1, /v1/embeddings 모두 입력 가능 (코드에서 자동 보정)
RAG_EMBED_BASE_URL=
# 임베딩 모델명
RAG_EMBED_MODEL=BAAI/bge-m3
# 임베딩 API Key가 필요한 경우 입력
RAG_EMBED_API_KEY=
# 임베딩 API 타임아웃(초)
RAG_EMBED_TIMEOUT_SEC=30

# legacy feedback RAG SQLite 경로
RAG_VECTOR_DB_PATH=migration.db
# legacy feedback RAG 테이블명
RAG_VECTOR_TABLE=feedback_rag_index
# legacy feedback RAG 검색 개수
RAG_TOP_K=5
# legacy feedback RAG corpus 최대 로드 건수
RAG_CORPUS_LIMIT=2000

# ==============================
# TOBE RAG
# ==============================
# TOBE RAG는 아래 SQLite/Faiss 설정을 사용함
# TOBE RAG의 임베딩 모델/엔드포인트는 위 RAG_EMBED_* 설정을 공통 사용함
TOBE_RAG_DB_PATH=migration.db
TOBE_RAG_FAISS_INDEX_PATH=migration_tobe_rag.faiss
TOBE_RAG_TABLE_CASE_MASTER=rag_case_master
TOBE_RAG_TABLE_CASE_DOC=rag_case_doc
TOBE_RAG_TOP_K_DENSE=12
TOBE_RAG_TOP_K_SPARSE=12
TOBE_RAG_TOP_K_RERANK=8
TOBE_RAG_TOP_K_PROMPT=4
TOBE_RAG_CORPUS_LIMIT=2000
TOBE_RAG_ENABLE_LEGACY_CORRECT_FALLBACK=Y
TOBE_RAG_PARSER_DIALECT=oracle
